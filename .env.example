# Database Configuration
CRAW_MYSQL_HOST=127.0.0.1:3306
CRAW_MYSQL_USERNAME=root
CRAW_MYSQL_PASSWORD=your_mysql_password_here
CRAW_MYSQL_DATABASE=craw

# Redis Configuration
CRAW_REDIS_HOST=127.0.0.1
CRAW_REDIS_PORT=6379
CRAW_REDIS_PASSWORD=your_redis_password_here

# JWT Configuration
CRAW_JWT_REALM=JWT
CRAW_JWT_KEY=your_jwt_secret_key_here
CRAW_JWT_TIMEOUT=24h
CRAW_JWT_MAX_REFRESH=24h

# Crawler Configuration (for cnhnb.com API)
CRAW_CRAWLER_DEVICE_ID=your_device_id_here
CRAW_CRAWLER_SECRET=your_crawler_secret_here

# Email Configuration
CRAW_EMAIL_HOST=smtp.qq.com
CRAW_EMAIL_PORT=465
CRAW_EMAIL_USERNAME=your_email@example.com
CRAW_EMAIL_PASSWORD=your_app_password_here
CRAW_EMAIL_FROM=your_email@example.com

# Doubao AI API Configuration
CRAW_DOUBAO_API_KEY=your_doubao_api_key_here
CRAW_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
CRAW_DOUBAO_MODEL=your_doubao_model_name_here

# Alert Configuration (if applicable)
CRAW_ALERT_WEBHOOK_URL=