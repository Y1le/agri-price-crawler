CRAW_CRON_DAILY_EMAIL_TIME="23 1 * * *"
CRAW_CRON_DAILY_CRAW_TIME="54 0 * * *"

# Log Configuration
CRAW_LOG_NAME=crawserver
CRAW_LOG_DEVELOPMENT=true
CRAW_LOG_LEVEL=debug
CRAW_LOG_FORMAT=console
CRAW_LOG_ENABLE_COLOR=true
CRAW_LOG_DISABLE_CALLER=false
CRAW_LOG_DISABLE_STACKTRACE=false
CRAW_LOG_OUTPUT_PATHS=D:/User/Desktop/GO/agri-price-crawler/var/crawserver.log,stdout
CRAW_LOG_ERROR_OUTPUT_PATHS=D:/User/Desktop/GO/agri-price-crawler/var/crawserver.error.log

# Feature Configuration
CRAW_FEATURE_ENABLE_METRICS=true
CRAW_FEATURE_PROFILING=true

# Server Configuration
CRAW_SERVER_MODE=debug
CRAW_SERVER_HEALTHZ=true
CRAW_SERVER_MIDDLEWARES=recovery,logger,secure,nocache,cors,dump
CRAW_SERVER_MAX_PING_COUNT=3

# GRPC Configuration
CRAW_GRPC_BIND_ADDRESS=0.0.0.0
CRAW_GRPC_BIND_PORT=8081

# Insecure HTTP Configuration
CRAW_INSECURE_BIND_ADDRESS=127.0.0.1
CRAW_INSECURE_BIND_PORT=8080

# Secure HTTPS Configuration
CRAW_SECURE_BIND_ADDRESS=0.0.0.0
CRAW_SECURE_BIND_PORT=8443
CRAW_SECURE_CERT_FILE=./craw.pem
CRAW_SECURE_PRIVATE_KEY_FILE=./craw-key.pem